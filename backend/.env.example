# JogjaSplorasi Backend - real PostgreSQL setup
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jogjasplorasi?schema=public
JWT_SECRET=dev_jogjasplorasi_secret_change_later_32_chars_minimum
JWT_EXPIRES_IN=7d
PUBLIC_BASE_URL=http://localhost:3000

# Development localhost/web/emulator. Untuk production, isi domain frontend yang valid.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:5500,http://127.0.0.1:5500
JSON_LIMIT=2mb
LOG_LEVEL=debug
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000
UPLOAD_RATE_LIMIT_MAX=80
AVATAR_MAX_SIZE=2097152
BACKUP_DIR=./backups
AI_GUIDE_MODE=local
AI_GUIDE_MAX_CONTEXT_DESTINATIONS=8
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
