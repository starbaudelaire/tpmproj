# Jogjasplorasi Backend - local real PostgreSQL setup
NODE_ENV=development

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Database
# Sesuaikan dengan PostgreSQL lokal Anda.
# Dari env terakhir Anda, yang aktif kemungkinan port 5434 dan password admin.
DATABASE_URL=postgresql://postgres:admin@localhost:5434/jogjasplorasi?schema=public

# Auth
JWT_SECRET=dev_jogjasplorasi_secret_change_later_32_chars_minimum
JWT_EXPIRES_IN=7d

# CORS
# Untuk development Flutter Web / local testing.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:5500,http://127.0.0.1:5500

# Limits & Logs
JSON_LIMIT=2mb
LOG_LEVEL=debug

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000
UPLOAD_RATE_LIMIT_MAX=80

# Upload
AVATAR_MAX_SIZE=2097152

# Backup
BACKUP_DIR=./backups

# AI Guide
# Pilihan: local, gemini, openrouter
AI_GUIDE_MODE=gemini
AI_GUIDE_MAX_CONTEXT_DESTINATIONS=8

# Google Gemini
GEMINI_API_KEY=AIzaSyC17SThzfATDrczx5WcNeLuj-eiuJNlJzQ
GEMINI_MODEL=gemini-1.5-flash

# OpenRouter, dikosongkan jika tidak dipakai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini